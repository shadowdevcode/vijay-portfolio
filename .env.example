# ============================================
# Vijay Sehgal — Portfolio Environment Variables
# ============================================
# Copy this file to .env and fill in real values.
#   cp .env.example .env
#
# IMPORTANT: Never commit .env — it is gitignored.
# The API key is used server-side only (Vercel
# serverless function). It is NOT exposed to the
# browser.
# ============================================

GEMINI_API_KEY=your_gemini_api_key_here
